{
  "defaultProvider": "ollama",
  "providers": {
    "ollama": {
      "baseUrl": "http://localhost:11434/v1",
      "toolMode": "auto"
    }
  },
  "roles": {
    "orchestrator": {
      "provider": "ollama",
      "model": "qwen3:14b",
      "temperature": 0.15
    },
    "coder": {
      "provider": "ollama",
      "model": "qwen3-coder:30b",
      "temperature": 0.15
    },
    "architect": {
      "provider": "ollama",
      "model": "qwen3:14b",
      "temperature": 0.2
    },
    "reviewer": {
      "provider": "ollama",
      "model": "qwen3:14b",
      "temperature": 0.1
    },
    "judge": {
      "provider": "ollama",
      "model": "qwen3:14b",
      "temperature": 0.1
    },
    "compactor": {
      "provider": "ollama",
      "model": "qwen3:14b",
      "temperature": 0.1
    }
  },
  "agent": {
    "maxTurns": 24,
    "maxReviewFixes": 1,
    "maxToolOutputCharacters": 12000,
    "keepRecentToolResults": 6,
    "maxParallelReadAgents": 1
  },
  "compaction": {
    "auto": true,
    "contextWindowTokens": 32768,
    "reservedTokens": 4096,
    "triggerCharacters": 80000,
    "keepRecentMessages": 6,
    "maxSummaryCharacters": 16000,
    "prompt": "Preserve user requirements, decisions, relevant files, completed changes, verification results, unresolved errors, and exact next steps. Remove repetition and conversational filler."
  },
  "codeIndex": {
    "enabled": true,
    "backend": "auto",
    "prewarm": true,
    "maxFiles": 10000,
    "cacheTtlMs": 5000,
    "maxResults": 20,
    "mapMaxCharacters": 12000
  },
  "memory": {
    "cognee": {
      "enabled": false,
      "baseUrl": "http://localhost:8000",
      "authMode": "x-api-key",
      "timeoutMs": 2000,
      "maxResults": 6,
      "maxContextCharacters": 8000,
      "maxRememberCharacters": 16000,
      "sessionAware": true,
      "rememberCompletedTurns": true,
      "rememberCompactions": true
    }
  },
  "telemetry": {
    "enabled": false,
    "serviceName": "jevio",
    "exporter": "console",
    "endpointEnv": "OTEL_EXPORTER_OTLP_ENDPOINT",
    "sampleRatio": 1
  },
  "plugins": {
    "mcp": {
      "example": {
        "enabled": false,
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-everything"],
        "env": {},
        "cwd": ".",
        "roles": ["coder", "reviewer"],
        "startupTimeoutMs": 10000
      }
    }
  },
  "permissions": {
    "autoApproveWorkspaceWrites": false,
    "autoApproveShell": false,
    "autoApprovePlugins": false,
    "shellMode": "tests-only"
  }
}
