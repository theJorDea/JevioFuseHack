{
  "name": "jevio",
  "version": "0.1.0",
  "description": "Local-first coding agent and multi-model orchestrator",
  "type": "module",
  "bin": {
    "jevio": "./bin/jevio.mjs"
  },
  "files": [
    "bin",
    "src",
    "web",
    "README.md",
    "LICENSE",
    "jevio.config.example.json"
  ],
  "scripts": {
    "start": "node src/cli.ts",
    "web": "node src/web-server.ts",
    "test": "node scripts/run-tests.mjs test/*.test.ts",
    "test:cloud": "node scripts/run-tests.mjs test/cloud-memory.integration.ts",
    "benchmark:memory": "node scripts/memory-benchmark.mjs",
    "benchmark:memory:check": "node scripts/check-memory-benchmark.mjs",
    "benchmark:coding": "node scripts/coding-benchmark.mjs",
    "check": "node --check src/cli.ts"
  },
  "engines": {
    "node": ">=22.19"
  },
  "license": "MIT",
  "dependencies": {
    "@earendil-works/pi-tui": "^0.80.5",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0"
  }
}
